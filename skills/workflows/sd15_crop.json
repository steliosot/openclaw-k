{
  "1": {
    "class_type": "LoadImage",
    "inputs": {"image": "{{image}}"}
  },
  "2": {
    "class_type": "ImageCrop",
    "inputs": {
      "image": ["1", 0],
      "x": "{{x}}",
      "y": "{{y}}",
      "width": "{{width}}",
      "height": "{{height}}"
    }
  },
  "3": {
    "class_type": "SaveImage",
    "inputs": {"images": ["2", 0], "filename_prefix": "openclaw_crop"}
  }
}
